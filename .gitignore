# ---- live-build working & output artifacts (never commit) ----
/.build/
/cache/
/chroot/
/chroot.packages.*
/binary/
/binary.*
/local/
/.stage/
# Note: auto/ holds only our authored config/build/clean scripts -- tracked.

# live-build regenerates everything under config/ that is not part of our
# source-of-truth. Track only the directories we author (see .gitignore rules
# below); ignore the machine-generated control files lb writes there.
/config/binary
/config/bootstrap
/config/chroot
/config/common
/config/source
/config/build

# `lb config` regenerates this default live package list every run.
/config/package-lists/live.list.chroot

# `lb config` also symlinks stock hooks into config/hooks/live/ (none authored).
/config/hooks/live/

# `lb config` symlinks live-build's stock hooks into config/hooks/normal/.
# Ignore everything there, then force-track only the hooks we author.
/config/hooks/normal/*
!/config/hooks/normal/0100-branding.hook.chroot
!/config/hooks/normal/0100-grub-theme.hook.binary
!/config/hooks/normal/0200-dconf.hook.chroot
!/config/hooks/normal/0300-zfs-check.hook.chroot
!/config/hooks/normal/0900-initramfs.hook.chroot
!/config/hooks/normal/9000-release-scrub.hook.chroot

# Build-mode marker written by scripts/build.sh (consumed by a chroot hook)
/config/includes.chroot/etc/.bs-buildmode

# Generated installer/runtime caches
*.log
*.iso
*.img
*.qcow2
*.contents
*.packages
*.files
chroot.files

# QEMU runtime state
/run/
/dist/

# Editor / OS noise
.DS_Store
*.swp
*~

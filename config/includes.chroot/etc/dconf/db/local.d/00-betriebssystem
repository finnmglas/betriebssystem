# System-wide GNOME defaults for BETRIEBSSYSTEM.
# Applied by the 0300-dconf-update chroot hook (`dconf update`).

[org/gnome/desktop/background]
picture-uri='file:///usr/share/backgrounds/betriebssystem/wallpaper.png'
picture-uri-dark='file:///usr/share/backgrounds/betriebssystem/wallpaper.png'
picture-options='zoom'
primary-color='#000000'
secondary-color='#000000'

[org/gnome/desktop/screensaver]
picture-uri='file:///usr/share/backgrounds/betriebssystem/wallpaper.png'
picture-options='zoom'
primary-color='#000000'

[org/gnome/desktop/interface]
color-scheme='prefer-dark'
gtk-theme='Adwaita-dark'
enable-animations=true
enable-hot-corners=true
clock-show-weekday=true
show-battery-percentage=true

[org/gnome/mutter]
edge-tiling=true
dynamic-workspaces=true

[org/gnome/desktop/input-sources]
# German keyboard layout; system language stays English (en_US.UTF-8).
sources=[('xkb', 'de')]
xkb-options=['terminate:ctrl_alt_bksp']

[org/gnome/nautilus/preferences]
default-folder-viewer='list-view'
show-hidden-files=true
show-delete-permanently=true
show-create-link=true
click-policy='double'
recursive-search='always'
show-image-thumbnails='always'

[org/gnome/nautilus/list-view]
use-tree-view=true
default-zoom-level='small'
default-visible-columns=['name', 'size', 'type', 'date_modified']

[org/gtk/settings/file-chooser]
show-hidden=true
sort-directories-first=true

[org/gtk/gtk4/settings/file-chooser]
show-hidden=true
sort-directories-first=true

[org/gnome/desktop/peripherals/touchpad]
tap-to-click=true
natural-scroll=true

[org/gnome/login-screen]
logo='/usr/share/pixmaps/betriebssystem-logo.png'
disable-user-list=false

[org/gnome/shell]
# Dash favorites, in order: Firefox, Files, Logseq, VS Code, Android Studio,
# Disks, Task Manager (System Monitor), Terminal. Logseq/Android Studio arrive
# via the first-boot Flatpak/tarball install; GNOME silently ignores a favorite
# whose .desktop is not (yet) present.
favorite-apps=['firefox-esr.desktop', 'org.gnome.Nautilus.desktop', 'com.logseq.Logseq.desktop', 'code.desktop', 'com.google.AndroidStudio.desktop', 'org.gnome.DiskUtility.desktop', 'org.gnome.SystemMonitor.desktop', 'org.gnome.Terminal.desktop']
# Tiling Assistant: quarter/corner tiling + tiling popup (beyond GNOME's halves).
enabled-extensions=['tiling-assistant@leleat-on-github']

[Default Applications]
# --- Emulators (ROMs) ---
application/x-gba-rom=betriebssystem-mgba.desktop
application/x-gameboy-rom=betriebssystem-mgba.desktop
application/x-nes-rom=betriebssystem-nestopia.desktop
application/x-n64-rom=betriebssystem-mupen64.desktop
application/x-nds-rom=betriebssystem-desmume.desktop
# --- Windows / Android ---
application/x-ms-dos-executable=wine-exe.desktop
application/x-msi=wine-exe.desktop
application/vnd.android.package-archive=betriebssystem-apk.desktop
# --- Images -> Loupe ---
image/jpeg=org.gnome.Loupe.desktop
image/png=org.gnome.Loupe.desktop
image/gif=org.gnome.Loupe.desktop
image/webp=org.gnome.Loupe.desktop
image/tiff=org.gnome.Loupe.desktop
image/bmp=org.gnome.Loupe.desktop
image/heif=org.gnome.Loupe.desktop
image/svg+xml=org.gnome.Loupe.desktop
# --- Video / Audio -> VLC (codecs make everything play) ---
video/mp4=vlc.desktop
video/x-matroska=vlc.desktop
video/webm=vlc.desktop
video/quicktime=vlc.desktop
video/x-msvideo=vlc.desktop
video/mpeg=vlc.desktop
audio/mpeg=vlc.desktop
audio/flac=vlc.desktop
audio/x-wav=vlc.desktop
audio/ogg=vlc.desktop
audio/mp4=vlc.desktop
# --- 3D models -> f3d viewer ---
model/stl=betriebssystem-3d.desktop
model/obj=betriebssystem-3d.desktop
model/gltf+json=betriebssystem-3d.desktop
model/gltf-binary=betriebssystem-3d.desktop
application/x-3d-model=betriebssystem-3d.desktop
# --- Blender projects ---
application/x-blender=blender.desktop
# --- Folders ALWAYS open in Nautilus (incl. VS Code "Open Containing Folder") ---
inode/directory=org.gnome.Nautilus.desktop
# --- Code / text / data files -> VS Code (gedit + gnome-text-editor as fallback) ---
text/plain=code.desktop
text/markdown=code.desktop
text/csv=code.desktop
text/css=code.desktop
text/x-python=code.desktop
text/x-csrc=code.desktop
text/x-c++src=code.desktop
text/x-chdr=code.desktop
text/x-c++hdr=code.desktop
text/x-java=code.desktop
text/x-go=code.desktop
text/rust=code.desktop
text/x-sql=code.desktop
text/x-shellscript=code.desktop
text/x-lua=code.desktop
text/x-tex=code.desktop
text/x-log=code.desktop
application/json=code.desktop
application/x-yaml=code.desktop
application/yaml=code.desktop
application/toml=code.desktop
application/xml=code.desktop
text/xml=code.desktop
application/javascript=code.desktop
application/x-shellscript=code.desktop
application/x-php=code.desktop
application/x-ruby=code.desktop

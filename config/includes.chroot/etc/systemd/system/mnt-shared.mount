[Unit]
Description=BETRIEBSSYSTEM host<->VM shared folder (QEMU 9p)
# Only attempt inside a VM, so bare-metal installs never show a failed unit.
ConditionVirtualization=vm
DefaultDependencies=no
After=local-fs-pre.target
Before=local-fs.target

[Mount]
What=bsshared
Where=/mnt/shared
Type=9p
Options=trans=virtio,version=9p2000.L,access=any,rw,nofail,_netdev

[Install]
WantedBy=multi-user.target

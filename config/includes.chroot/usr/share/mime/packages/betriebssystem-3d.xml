<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <!-- 3D model formats that shared-mime-info may not cover, so Nautilus has a
       type to associate with the f3d viewer. (stl/obj/gltf/glb are already
       model/* types and are bound separately in mimeapps.list.) -->
  <mime-type type="application/x-3d-model">
    <comment>3D model</comment>
    <glob pattern="*.fbx"/>
    <glob pattern="*.3ds"/>
    <glob pattern="*.dae"/>
    <glob pattern="*.ply"/>
    <glob pattern="*.off"/>
    <glob pattern="*.x3d"/>
    <glob pattern="*.wrl"/>
    <glob pattern="*.3mf"/>
  </mime-type>
</mime-info>

{
  "policies": {
    "OverrideFirstRunPage": "",
    "OverridePostUpdatePage": "",
    "DontCheckDefaultBrowser": true,
    "DisableProfileImport": true,
    "DisableTelemetry": true,
    "DisableFirefoxStudies": true,
    "DisablePocket": true,
    "DisableFeedbackCommands": true,
    "NoDefaultBookmarks": true,
    "UserMessaging": {
      "WhatsNew": false,
      "ExtensionRecommendations": false,
      "FeatureRecommendations": false,
      "UrlbarInterventions": false,
      "SkipOnboarding": true,
      "MoreFromMozilla": false
    },
    "SearchEngines": {
      "Default": "Google"
    },
    "Extensions": {
      "Install": [
        "https://addons.mozilla.org/firefox/downloads/latest/ublock-origin/latest.xpi",
        "https://addons.mozilla.org/firefox/downloads/latest/multi-account-containers/latest.xpi",
        "https://addons.mozilla.org/firefox/downloads/latest/cookie-editor/latest.xpi"
      ]
    },
    "Preferences": {
      "browser.toolbars.bookmarks.visibility": { "Value": "always", "Status": "default" }
    },
    "Bookmarks": [
      { "Title": "Search",         "URL": "https://www.google.com",    "Placement": "toolbar" },
      { "Title": "Company Search", "URL": "https://www.northdata.com", "Placement": "toolbar" },
      { "Title": "Face search",    "URL": "https://pimeyes.com",       "Placement": "toolbar" },
      { "Title": "", "URL": "https://github.com",      "Placement": "toolbar", "Favicon": "https://github.com/favicon.ico" },
      { "Title": "", "URL": "https://claude.ai",       "Placement": "toolbar", "Favicon": "https://claude.ai/favicon.ico" },
      { "Title": "", "URL": "https://web.whatsapp.com", "Placement": "toolbar", "Favicon": "https://web.whatsapp.com/favicon.ico" }
    ]
  }
}
